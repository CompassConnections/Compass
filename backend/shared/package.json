    "firebase-admin": "13.5.0",
    "gcp-metadata": "6.1.0",
    "lodash": "4.17.23",
    "pg-promise": "12.6.1",
    "pg-query-stream": "4.12.0",
    "posthog-node": "4.11.0",
    "string-similarity": "4.0.4"
  },
  "devDependencies": {
    "@types/jest": "^29",
    "@types/lodash": "^4.17.0",
    "jest": "^29",
    "ts-jest": "29.4.6"
  }
