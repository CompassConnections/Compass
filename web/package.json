    "@tailwindcss/typography": "^0.5.13",
    "@types/d3": "7.4.0",
    "@types/jest": "^29",
    "@types/lodash": "^4.17.0",
    "@types/node": "20.19.35",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.27",
    "concurrently": "8.2.2",
    "cross-env": "7.0.3",
    "next-sitemap": "4.2.3",
    "postcss": "8.5.6",
    "tsc-files": "1.1.3"
  }
